{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "products-route": {
        "ClusterId": "product-service",
        "Match": { "Path": "/api/products/{**catch-all}" }
      },
      "orders-route": {
        "ClusterId": "order-service",
        "Match": { "Path": "/api/orders/{**catch-all}" }
      },
      "customers-route": {
        "ClusterId": "customer-service",
        "Match": { "Path": "/api/customers/{**catch-all}" }
      },
      "cart-route": {
        "ClusterId": "cart-service",
        "Match": { "Path": "/api/cart/{**catch-all}" }
      },
      "search-route": {
        "ClusterId": "search-service",
        "Match": { "Path": "/api/search/{**catch-all}" }
      },
      "payments-route": {
        "ClusterId": "payment-service",
        "Match": { "Path": "/api/payments/{**catch-all}" }
      },
      "inventory-route": {
        "ClusterId": "inventory-service",
        "Match": { "Path": "/api/inventory/{**catch-all}" }
      }
    },
    "Clusters": {
      "product-service":    { "Destinations": { "default": { "Address": "http://product-service:8080" } } },
      "order-service":      { "Destinations": { "default": { "Address": "http://order-service:8080" } } },
      "customer-service":   { "Destinations": { "default": { "Address": "http://customer-service:8080" } } },
      "cart-service":       { "Destinations": { "default": { "Address": "http://cart-service:8080" } } },
      "search-service":     { "Destinations": { "default": { "Address": "http://search-service:8080" } } },
      "payment-service":    { "Destinations": { "default": { "Address": "http://payment-service:8080" } } },
      "inventory-service":  { "Destinations": { "default": { "Address": "http://inventory-service:8080" } } }
    }
  }
}
